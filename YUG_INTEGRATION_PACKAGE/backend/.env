# DarkIntel-AI Backend Configuration
# Copy from .env.example and fill in your values

# API Keys (get from API_SETUP_GUIDE.md)
GROQ_API_KEY=gsk_your_groq_api_key_here
ALCHEMY_API_KEY=your_alchemy_api_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Demo Mode (true = use static data, false = live API calls)
DEMO_MODE=true

# Tor Configuration
TOR_PROXY=127.0.0.1:9050
TOR_ENABLED=false

# Database
DATABASE_URL=sqlite:///./darkintel.db

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging Level
LOG_LEVEL=INFO

# Optional: Redis (for caching - not required for hackathon)
# REDIS_URL=redis://localhost:6379

# Module Endpoints (for inter-service communication)
NLP_SERVICE_URL=http://localhost:8001
BLOCKCHAIN_SERVICE_URL=http://localhost:8002
CRAWLER_SERVICE_URL=http://localhost:8003
